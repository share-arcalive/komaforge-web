+    // 선택 구간이 있으면 그 구간의 런에 set을 적용하고, 없으면 문서 기본값(setDefault)을 바꾼다. 이후 재분할.
+    private void ApplyFlowSelectionStyle(System.Action<FlowTextRun> set, System.Action setDefault)
+    {
