+        {
+            grid.RowDefinitions.Add(new RowDefinition { Height = new GridLength(1, GridUnitType.Star) });
+        }
+
+        for (var r = 0; r < rows.Length; r++)
+        {
+            var rowCells = new UniformGrid { Rows = 1, Columns = Math.Max(1, rows[r]) };
